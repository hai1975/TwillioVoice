# Gemini API (lấy tại https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key
# Chế độ voice: conversationrelay (khuyến nghị) hoặc live (Gemini Live native audio)
VOICE_MODE=conversationrelay
CHAT_MODEL=gemini-2.5-flash
MODEL=gemini-2.5-flash-native-audio-preview-12-2025

SYSTEM_INSTRUCTION=You are the friendly phone receptionist for VM Clinic. Answer in clear English, keep responses short and natural for a phone call.
GREETING=Thanks for calling VM Clinic. Can I help you today?

# ConversationRelay — tiếng Anh (VM Clinic)
CR_LANGUAGE=en-US
CR_VOICE=UgBBYS2sOqTuMpoF3BR0

# Twilio (lấy tại https://console.twilio.com)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Host công khai (ngrok hoặc Cloud Run), KHÔNG có https://
# VD: abc123.ngrok-free.app hoặc your-service-xxx.run.app
TWILIO_APP_HOST=your-ngrok-subdomain.ngrok-free.app

# Tùy chỉnh VoiceBot (tùy chọn)
SYSTEM_INSTRUCTION=Bạn là trợ lý AI thân thiện. Trả lời bằng tiếng Việt, ngắn gọn và tự nhiên.
VOICE_NAME=Puck
GREETING=Chào người gọi bằng tiếng Việt và hỏi bạn có thể giúp gì.

# Server port (mặc định 8000)
PORT=8000

# Gemini API (lấy tại https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key

# live = Gemini Live duplex (đa ngôn ngữ) | conversationrelay = Twilio STT/TTS
VOICE_MODE=conversationrelay
MODEL=gemini-2.5-flash-native-audio-preview-12-2025
CHAT_MODEL=gemini-2.5-flash

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_APP_HOST=your-app.onrender.com

# Gemini Live
SYSTEM_INSTRUCTION=You are VM Clinic receptionist. Reply in the same language the caller uses. Keep answers short.
GREETING=Greet the caller warmly as VM Clinic receptionist and ask how you can help today.
VOICE_NAME=Puck

# ConversationRelay (chỉ khi VOICE_MODE=conversationrelay)
CR_LANGUAGE=en-US
CR_VOICE=UgBBYS2sOqTuMpoF3BR0

PORT=8000

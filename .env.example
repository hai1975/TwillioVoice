# Gemini API (lấy tại https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key
MODEL=gemini-2.5-flash-live-preview

# Twilio (lấy tại https://console.twilio.com)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Host công khai (ngrok hoặc Cloud Run), KHÔNG có https://
# VD: abc123.ngrok-free.app hoặc your-service-xxx.run.app
TWILIO_APP_HOST=your-ngrok-subdomain.ngrok-free.app

# Tùy chỉnh VoiceBot (tùy chọn)
SYSTEM_INSTRUCTION=Bạn là trợ lý AI thân thiện. Trả lời bằng tiếng Việt, ngắn gọn và tự nhiên.
VOICE_NAME=Puck
GREETING=Chào người gọi bằng tiếng Việt và hỏi bạn có thể giúp gì.

# Server port (mặc định 8000)
PORT=8000
